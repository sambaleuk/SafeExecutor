{
  "name": "safe-executor",
  "version": "0.1.0",
  "description": "A harness for safe, gate-enforced execution of operations on sensitive systems. Inspired by Modragor.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "safe-executor": "./dist/bin/safe-executor-mcp.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./mcp-server": {
      "import": "./dist/mcp-server/index.js",
      "types": "./dist/mcp-server/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "plugin/",
    "config/policies/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist",
    "mcp": "node dist/bin/safe-executor-mcp.js",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "database",
    "safety",
    "harness",
    "postgres",
    "sql",
    "audit",
    "approval",
    "dry-run",
    "production",
    "mcp",
    "model-context-protocol",
    "claude",
    "llm-safety",
    "policy-engine"
  ],
  "author": "sambaleuk",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sambaleuk/SafeExecutor.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "ajv": "^8.17.1",
    "node-sql-parser": "^5.4.0",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.0.0",
    "@types/node-sql-parser": "^1.0.0",
    "@types/pg": "^8.11.10",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
